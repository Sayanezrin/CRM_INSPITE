{
  "name": "inspite-people-system",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "client": "cd client && npm run dev",
    "server": "cd server && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm install && npm run build && cd .. && node scripts/copy-client-dist.mjs",
    "server:check": "cd server && npm run check"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "google-auth-library": "^10.9.0",
    "mongodb": "^6.12.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
